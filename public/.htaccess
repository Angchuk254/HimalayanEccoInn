# Himalayan Eco Inn - Apache config for prerendered static site
# Prerendered pages: /, /about, /rooms, etc. have their own index.html
# Admin and 404: fallback to index.html for client-side routing

RewriteEngine On
RewriteBase /

# If not a real file or directory, serve index.html (admin, 404)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Ensure correct MIME types
<IfModule mod_mime.c>
  AddType application/xml .xml
</IfModule>
